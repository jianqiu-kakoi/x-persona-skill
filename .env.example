# Official X API v2 credentials for scripts/fetch_xapi.mjs.
# Copy this file to `.env` (gitignored) and fill in your values.
#
# Provide EITHER a Bearer Token (simplest — copy from the X developer portal):
X_BEARER_TOKEN=
#
# OR the Consumer Key + Secret pair (the script exchanges them for a Bearer).
# Both are required together; you do NOT need Access Token/Secret for read-only.
X_API_KEY=
X_API_SECRET=
